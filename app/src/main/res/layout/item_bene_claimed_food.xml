<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_claimed_card"
    android:gravity="center"
    android:padding="25dp"
    android:layout_marginTop="20dp">

    <ImageView
        android:id="@+id/ivClaimedFoodImg"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/logo"
        android:scaleType="centerCrop"/>

    <TextView
        android:id="@+id/tvClaimedFoodName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Food Name"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="#457B9D"
        android:layout_marginTop="10dp"/>

    <TextView
        android:id="@+id/tvClaimedFoodDesc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Details"
        android:gravity="center"
        android:textColor="#666666"
        android:layout_marginTop="5dp"/>

    <TextView
        android:id="@+id/tvClaimedStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status - Claimed"
        android:background="@drawable/bg_status_pill"
        android:paddingHorizontal="20dp"
        android:paddingVertical="8dp"
        android:layout_marginTop="15dp"
        android:textStyle="bold"
        android:textColor="#457B9D"/>

</LinearLayout>